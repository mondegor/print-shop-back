# Mapping ENV vars to ../config/config.go
# if ENV var not exists put default value from ./app/config/config.yaml

## App vars:
# APPX_NAME="Print Shop Service"
# APPX_VER=v0.0.0
# APPX_ENV=local

## Log and debug:
APPX_DEBUG=false
APPX_ERR_CALLER_IS_ENABLED=false
APPX_ERR_CALLER_DEPTH=3
APPX_LOG_LEVEL=error # Log levels: info, warn, error, debug
APPX_LOG_TIME_FORMAT=RFC3339
APPX_LOG_JSON=true
APPX_LOG_COLOR=false
APPX_TRACE_IS_ENABLED=false

## Sentry:
APPX_SENTRY_DSN=
# APPX_SENTRY_TRACES_SAMPLE_RATE=1.0

## Http server:
# APPX_SERVER_READ_TIMEOUT=5s
# APPX_SERVER_WRITE_TIMEOUT=5s
# APPX_SERVER_SHUTDOWN_TIMEOUT=15s
# APPX_SERVER_LISTEN_BIND=0.0.0.0
# APPX_SERVER_LISTEN_PORT=8080

## Internal server:
# APPX_INTERNAL_SERVER_READ_TIMEOUT=5s
# APPX_INTERNAL_SERVER_WRITE_TIMEOUT=5s
# APPX_INTERNAL_SERVER_SHUTDOWN_TIMEOUT=15s
# APPX_INTERNAL_SERVER_LISTEN_BIND=0.0.0.0
# APPX_INTERNAL_SERVER_LISTEN_PORT=8084

## Postgres:
APPX_DB_HOST=testcontainer # 127.0.0.1
# APPX_DB_PORT=5432
# APPX_DB_USER=user_pg
# APPX_DB_PASSWORD=123456
# APPX_DB_NAME=db_pg
# APPX_DB_MIGRATIONS_TABLE=schema_migrations
# APPX_DB_MAX_POOL_SIZE=2

## Redis:
APPX_REDIS_HOST=testcontainer # 127.0.0.1
# APPX_REDIS_PORT=6379
# APPX_REDIS_PASSWORD=123456

## S3:
APPX_S3_HOST=127.0.0.1 # testcontainer
# APPX_S3_PORT=9000
# APPX_S3_USESSL=true
# APPX_S3_USER=admin
# APPX_S3_PASSWORD=12345678
# APPX_S3_CREATE_BUCKETS=true

## File system (disabled):
# APPX_FILESYSTEM_DIR_MODE=0775
# APPX_FILESYSTEM_CREATE_DIRS=true

## File providers:
# APPX_IMAGESTORAGE_ROOT_DIR=../img
# APPX_IMAGE_HOST=http://print-shop.local/

## Cors:
# APPX_CORS_ALLOWED_ORIGINS=http://print-shop.local,http://localhost:3000,http://127.0.0.1:3000

## Translation:
# APPX_TRANSLATION_DIR_PATH=./translate
# APPX_TRANSLATION_LANGS=ru-RU,en-US
# APPX_TRANSLATION_DICTIONARIES_DIR_PATH=./translate/dict

## Sender Mail:
# APPX_SENDER_MAIL_DEFAULT_FROM="PrintShop <username@yandex.ru>"
APPX_SENDER_MAIL_SMTP_HOST=
# APPX_SENDER_MAIL_SMTP_PORT=587
# APPX_SENDER_MAIL_SMTP_USERNAME=username
# APPX_SENDER_MAIL_SMTP_PASSWORD=password

## Sender Telegram:
APPX_SENDER_TELEGRAMBOT_NAME=
# APPX_SENDER_TELEGRAMBOT_TOKEN=0000000000:AAAaaAAaaAAaaAAAA0AAaaaaAaAAAAAAa_a

## Access control:
# APPX_ROLES_DIR_PATH=./roles
# APPX_JWT_SECRET=secret