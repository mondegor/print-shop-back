{
  "enabledPlugins": {
    "code-review@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(echo *)",
      "Bash(ls *)",
      "Bash(grep *)",
      "Bash(go build *)",
